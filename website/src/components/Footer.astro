---
import { url } from "../lib/url";
import { GITHUB_URL, docsNav } from "../lib/docs";
---

<footer class="footer">
  <div class="page footer-inner">
    <div class="footer-brand">
      <span class="brand">DevHQ</span>
      <p class="muted">A control plane for parallel, agent-driven development.</p>
    </div>
    <div class="footer-col">
      <span class="footer-head">Docs</span>
      {docsNav.slice(0, 4).map((d) => (
        <a href={url(`/docs/${d.slug}`)}>{d.title}</a>
      ))}
    </div>
    <div class="footer-col">
      <span class="footer-head">Project</span>
      <a href={GITHUB_URL} rel="noopener" target="_blank">GitHub</a>
      <a href={`${GITHUB_URL}/blob/main/install.sh`} rel="noopener" target="_blank">Installer</a>
      <a href="https://lite-xl.com/" rel="noopener" target="_blank">Lite XL</a>
    </div>
  </div>
  <div class="page footer-base muted">
    <span>Open source. Inspect the code.</span>
    <span>Built on Lite XL.</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border-soft);
    padding: 56px 0 40px;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 40px;
  }
  .footer-brand .brand {
    font-family: var(--font-mono);
    font-weight: 600;
  }
  .footer-brand p {
    margin-top: 10px;
    max-width: 320px;
    font-size: 14px;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-head {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--faint);
  }
  .footer-col a {
    font-size: 14px;
    color: var(--muted);
  }
  .footer-col a:hover {
    color: var(--text);
  }
  .footer-base {
    display: flex;
    justify-content: space-between;
    margin-top: 44px;
    padding-top: 22px;
    border-top: 1px solid var(--border-soft);
    font-size: 13px;
  }
  @media (max-width: 640px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }
</style>
